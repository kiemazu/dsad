import chess
import torch
import torch.nn as nn
import numpy as np
import pygame
import sys
import os
from pygame.locals import *

# ============ НЕЙРОСЕТЬ ============
class ChessNeuralNetwork(nn.Module):
    def __init__(self, num_moves):
        super(ChessNeuralNetwork, self).__init__()
        self.conv_layers = nn.Sequential(
            nn.Conv2d(12, 32, kernel_size=3, padding=1),
            nn.BatchNorm2d(32),
            nn.ReLU(),
            nn.Conv2d(32, 64, kernel_size=3, padding=1),
            nn.BatchNorm2d(64),
            nn.ReLU(),
            nn.Conv2d(64, 128, kernel_size=3, padding=1),
            nn.BatchNorm2d(128),
            nn.ReLU(),
        )
        self.fc_layers = nn.Sequential(
            nn.Flatten(),
            nn.Linear(128 * 8 * 8, 512),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(512, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, num_moves)
        )

    def forward(self, x):
        x = self.conv_layers(x)
        x = self.fc_layers(x)
        return x


# ============ КОНВЕРТАЦИЯ ДОСКИ В ТЕНЗОР ============
def board_to_tensor(board):
    tensor = np.zeros((12, 8, 8), dtype=np.float32)
    piece_to_idx = {chess.PAWN: 0, chess.KNIGHT: 1, chess.BISHOP: 2,
                    chess.ROOK: 3, chess.QUEEN: 4, chess.KING: 5}
    
    for square in chess.SQUARES:
        piece = board.piece_at(square)
        if piece:
            row = 7 - (square // 8)
            col = square % 8
            channel = piece_to_idx[piece.piece_type]
            if piece.color == chess.WHITE:
                tensor[channel][row][col] = 1.0
            else:
                tensor[channel + 6][row][col] = 1.0
    return tensor


# ============ ШАХМАТНЫЙ ДВИЖОК ============
class ChessEngine:
    def __init__(self, model_path='chess_engine_trained.pth'):
        print("Загрузка модели...")
        self.device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
        try:
            checkpoint = torch.load(model_path, map_location=self.device)
            self.idx_to_move = checkpoint['idx_to_move']
            self.model = ChessNeuralNetwork(len(self.idx_to_move)).to(self.device)
            self.model.load_state_dict(checkpoint['model_state_dict'])
            self.model.eval()
            print("Модель загружена!")
        except:
            print("Модель не найдена, буду ходить случайно")
            self.model = None
            self.idx_to_move = {}

    def get_best_move(self, board):
        if self.model is None:
            moves = list(board.legal_moves)
            return moves[0] if moves else None
        
        tensor = torch.FloatTensor(board_to_tensor(board)).unsqueeze(0).to(self.device)
        with torch.no_grad():
            probs = torch.softmax(self.model(tensor), dim=1)
        
        # Пробуем лучший ход
        best_idx = torch.argmax(probs, dim=1).item()
        best_move_str = self.idx_to_move[best_idx]
        try:
            move = chess.Move.from_uci(best_move_str)
            if move in board.legal_moves:
                return move
        except:
            pass
        
        # Если не получилось - берем любой легальный
        moves = list(board.legal_moves)
        return moves[0] if moves else None


# ============ ЗАГРУЗЧИК СПРАЙТОВ ============
def load_pieces(square_size):
    """Загружает спрайты из папки pieces/ с именами white_king.png, black_king.png и т.д."""
    pieces = {}
    
    # Соответствие символа фигуры -> имя файла
    file_names = {
        'P': 'white_pawn', 'N': 'white_knight', 'B': 'white_bishop',
        'R': 'white_rook', 'Q': 'white_queen', 'K': 'white_king',
        'p': 'black_pawn', 'n': 'black_knight', 'b': 'black_bishop',
        'r': 'black_rook', 'q': 'black_queen', 'k': 'black_king'
    }
    
    # Проверяем, существует ли папка pieces
    if not os.path.exists('pieces'):
        os.makedirs('pieces')
        print("\n=== ВНИМАНИЕ ===")
        print("Папка 'pieces' создана, но она пуста!")
        print("Положите туда изображения фигур в формате PNG:")
        print("  white_king.png, white_queen.png, white_rook.png,")
        print("  white_bishop.png, white_knight.png, white_pawn.png")
        print("  black_king.png, black_queen.png, black_rook.png,")
        print("  black_bishop.png, black_knight.png, black_pawn.png")
        print("Будут использоваться текстовые символы\n")
        return None
    
    # Загружаем изображения
    loaded = 0
    for symbol, filename in file_names.items():
        path = os.path.join('pieces', filename + '.png')
        if os.path.exists(path):
            try:
                img = pygame.image.load(path)
                img = pygame.transform.scale(img, (square_size - 10, square_size - 10))
                pieces[symbol] = img
                loaded += 1
            except:
                pieces[symbol] = None
        else:
            pieces[symbol] = None
    
    if loaded == 0:
        print("Изображения не найдены, использую текстовые символы")
        return None
    
    print(f"Загружено {loaded}/12 изображений фигур")
    return pieces


# ============ ГРАФИЧЕСКИЙ ИНТЕРФЕЙС ============
class ChessGUI:
    def __init__(self, engine):
        pygame.init()
        
        self.SQUARE_SIZE = 80
        self.BOARD_SIZE = 640
        self.INFO_WIDTH = 250
        
        self.screen = pygame.display.set_mode((self.BOARD_SIZE + self.INFO_WIDTH, self.BOARD_SIZE))
        pygame.display.set_caption("Шахматы против ИИ")
        
        # Цвета
        self.WHITE_SQ = (240, 217, 181)
        self.BLACK_SQ = (181, 136, 99)
        
        # Шрифты
        self.font_small = pygame.font.Font(None, 24)
        self.font_big = pygame.font.Font(None, 36)
        self.font_piece = pygame.font.Font(None, 52)  # Для текстовых фигур
        
        # Загружаем спрайты
        self.piece_images = load_pieces(self.SQUARE_SIZE)
        
        # Игровое состояние
        self.board = chess.Board()
        self.engine = engine
        self.selected = None
        self.legal_moves = []
        self.human_white = True
        self.game_over = False
        self.winner = None
        self.last_move = None
        self.waiting_engine = False
        
        # Кнопки
        self.new_game_btn = pygame.Rect(self.BOARD_SIZE + 20, 50, 210, 40)
        self.resign_btn = pygame.Rect(self.BOARD_SIZE + 20, 110, 210, 40)
    
    def draw_board(self):
        """Рисует доску"""
        for row in range(8):
            for col in range(8):
                x, y = col * self.SQUARE_SIZE, row * self.SQUARE_SIZE
                color = self.WHITE_SQ if (row + col) % 2 == 0 else self.BLACK_SQ
                pygame.draw.rect(self.screen, color, (x, y, self.SQUARE_SIZE, self.SQUARE_SIZE))
                
                # Подсветка последнего хода
                if self.last_move:
                    from_row = 7 - (self.last_move.from_square // 8)
                    from_col = self.last_move.from_square % 8
                    to_row = 7 - (self.last_move.to_square // 8)
                    to_col = self.last_move.to_square % 8
                    if (row, col) == (from_row, from_col) or (row, col) == (to_row, to_col):
                        s = pygame.Surface((self.SQUARE_SIZE, self.SQUARE_SIZE))
                        s.set_alpha(100)
                        s.fill((0, 200, 0))
                        self.screen.blit(s, (x, y))
                
                # Подсветка выбранной клетки
                if self.selected:
                    sel_row = 7 - (self.selected // 8)
                    sel_col = self.selected % 8
                    if (row, col) == (sel_row, sel_col):
                        s = pygame.Surface((self.SQUARE_SIZE, self.SQUARE_SIZE))
                        s.set_alpha(100)
                        s.fill((255, 255, 0))
                        self.screen.blit(s, (x, y))
                
                # Подсветка возможных ходов
                for move in self.legal_moves:
                    t_row = 7 - (move.to_square // 8)
                    t_col = move.to_square % 8
                    if (row, col) == (t_row, t_col):
                        center = (x + self.SQUARE_SIZE//2, y + self.SQUARE_SIZE//2)
                        pygame.draw.circle(self.screen, (0, 200, 0, 100), center, self.SQUARE_SIZE//5)
    
    def draw_pieces(self):
        """Рисует фигуры"""
        for square in chess.SQUARES:
            piece = self.board.piece_at(square)
            if piece:
                row = 7 - (square // 8)
                col = square % 8
                x, y = col * self.SQUARE_SIZE, row * self.SQUARE_SIZE
                symbol = piece.symbol()
                
                # Рисуем спрайт или текст
                if self.piece_images and symbol in self.piece_images and self.piece_images[symbol]:
                    img = self.piece_images[symbol]
                    x_center = x + (self.SQUARE_SIZE - img.get_width()) // 2
                    y_center = y + (self.SQUARE_SIZE - img.get_height()) // 2
                    self.screen.blit(img, (x_center, y_center))
                else:
                    # Текстовые символы (Unicode шахматные фигуры)
                    piece_unicode = {'K':'♔','Q':'♕','R':'♖','B':'♗','N':'♘','P':'♙',
                                    'k':'♚','q':'♛','r':'♜','b':'♝','n':'♞','p':'♟'}
                    text = self.font_piece.render(piece_unicode.get(symbol, symbol), True, (0,0,0))
                    x_center = x + (self.SQUARE_SIZE - text.get_width()) // 2
                    y_center = y + (self.SQUARE_SIZE - text.get_height()) // 2
                    self.screen.blit(text, (x_center, y_center))
    
    def draw_panel(self):
        """Рисует информационную панель"""
        panel_x = self.BOARD_SIZE
        pygame.draw.rect(self.screen, (50, 50, 50), (panel_x, 0, self.INFO_WIDTH, self.BOARD_SIZE))
        
        # Заголовок
        title = self.font_big.render("ШАХМАТЫ", True, (255,255,255))
        self.screen.blit(title, (panel_x + 75, 20))
        
        # Чей ход
        turn = "Белые" if self.board.turn == chess.WHITE else "Черные"
        is_human = (self.board.turn == chess.WHITE and self.human_white) or \
                   (self.board.turn == chess.BLACK and not self.human_white)
        turn_text = f"{turn} ({'Вы' if is_human else 'ИИ'})"
        turn_surf = self.font_small.render(turn_text, True, (255,255,255))
        self.screen.blit(turn_surf, (panel_x + 20, 100))
        
        # Кнопки
        for btn, text in [(self.new_game_btn, "Новая игра"), (self.resign_btn, "Сдаться")]:
            color = (70,70,70) if btn.collidepoint(pygame.mouse.get_pos()) else (100,100,100)
            pygame.draw.rect(self.screen, color, btn)
            pygame.draw.rect(self.screen, (150,150,150), btn, 2)
            txt = self.font_small.render(text, True, (255,255,255))
            self.screen.blit(txt, (btn.x + 20, btn.y + 12))
        
        # Конец игры
        if self.game_over:
            y = 180
            if self.winner:
                text = self.font_big.render(f"{self.winner} победили!", True, (255,255,0))
            else:
                text = self.font_big.render("Ничья!", True, (255,255,0))
            self.screen.blit(text, (panel_x + 20, y))
    
    def get_square(self, pos):
        """Получает клетку по координатам мыши"""
        x, y = pos
        if x < self.BOARD_SIZE and y < self.BOARD_SIZE:
            col = x // self.SQUARE_SIZE
            row = y // self.SQUARE_SIZE
            return (7 - row) * 8 + col
        return None
    
    def handle_click(self, pos):
        """Обработка клика"""
        # Кнопки
        if self.new_game_btn.collidepoint(pos):
            self.new_game()
            return
        if self.resign_btn.collidepoint(pos) and not self.game_over:
            self.game_over = True
            self.winner = "Черные" if self.board.turn == chess.WHITE else "Белые"
            return
        
        if self.game_over or self.waiting_engine:
            return
        
        square = self.get_square(pos)
        if square is None:
            return
        
        # Проверяем, чей ход
        is_human = (self.board.turn == chess.WHITE and self.human_white) or \
                   (self.board.turn == chess.BLACK and not self.human_white)
        if not is_human:
            return
        
        # Выбор или ход
        if self.selected is None:
            piece = self.board.piece_at(square)
            if piece and piece.color == self.board.turn:
                self.selected = square
                self.legal_moves = [m for m in self.board.legal_moves if m.from_square == square]
        else:
            move = chess.Move(self.selected, square)
            # Превращение пешки
            piece = self.board.piece_at(self.selected)
            if piece and piece.piece_type == chess.PAWN:
                to_row = 7 - (square // 8)
                if (piece.color == chess.WHITE and to_row == 0) or (piece.color == chess.BLACK and to_row == 7):
                    move = chess.Move(self.selected, square, promotion=chess.QUEEN)
            
            if move in self.board.legal_moves:
                self.board.push(move)
                self.last_move = move
                self.selected = None
                self.legal_moves = []
                self.check_game_over()
                if not self.game_over:
                    self.waiting_engine = True
            else:
                self.selected = None
                self.legal_moves = []
    
    def check_game_over(self):
        """Проверка конца игры"""
        if self.board.is_game_over():
            self.game_over = True
            if self.board.is_checkmate():
                self.winner = "Черные" if self.board.turn == chess.WHITE else "Белые"
            else:
                self.winner = None
    
    def engine_move(self):
        """Ход движка"""
        if not self.waiting_engine or self.game_over:
            return
        move = self.engine.get_best_move(self.board)
        if move:
            self.board.push(move)
            self.last_move = move
            self.check_game_over()
        self.waiting_engine = False
    
    def new_game(self):
        """Новая игра"""
        self.board = chess.Board()
        self.selected = None
        self.legal_moves = []
        self.game_over = False
        self.winner = None
        self.last_move = None
        self.waiting_engine = False
        if not self.human_white:
            self.waiting_engine = True
    
    def choose_color(self):
        """Диалог выбора цвета"""
        dialog = pygame.Surface((300, 200))
        dialog.set_alpha(200)
        dialog.fill((0,0,0))
        self.screen.blit(dialog, (220, 220))
        pygame.draw.rect(self.screen, (100,100,100), (220,220,300,200), 2)
        
        white_btn = pygame.Rect(250, 300, 100, 40)
        black_btn = pygame.Rect(390, 300, 100, 40)
        
        text = self.font_big.render("Выберите цвет", True, (255,255,255))
        self.screen.blit(text, (280, 260))
        
        pygame.draw.rect(self.screen, (70,70,70), white_btn)
        pygame.draw.rect(self.screen, (70,70,70), black_btn)
        w_text = self.font_small.render("Белые", True, (255,255,255))
        b_text = self.font_small.render("Черные", True, (255,255,255))
        self.screen.blit(w_text, (280, 310))
        self.screen.blit(b_text, (420, 310))
        pygame.display.flip()
        
        waiting = True
        while waiting:
            for event in pygame.event.get():
                if event.type == MOUSEBUTTONDOWN:
                    if white_btn.collidepoint(event.pos):
                        self.human_white = True
                        waiting = False
                    elif black_btn.collidepoint(event.pos):
                        self.human_white = False
                        waiting = False
            pygame.time.wait(50)
    
    def run(self):
        """Главный цикл"""
        self.choose_color()
        if not self.human_white:
            self.waiting_engine = True
        
        clock = pygame.time.Clock()
        running = True
        
        while running:
            for event in pygame.event.get():
                if event.type == QUIT:
                    running = False
                elif event.type == MOUSEBUTTONDOWN:
                    self.handle_click(event.pos)
                elif event.type == KEYDOWN:
                    if event.key == K_ESCAPE:
                        running = False
                    elif event.key == K_r:
                        self.new_game()
            
            if self.waiting_engine and not self.game_over:
                self.engine_move()
                pygame.time.wait(200)
            
            self.draw_board()
            self.draw_pieces()
            self.draw_panel()
            pygame.display.flip()
            clock.tick(60)
        
        pygame.quit()
        sys.exit()


# ============ ЗАПУСК ============
if __name__ == "__main__":
    engine = ChessEngine('chess_engine_trained.pth')
    game = ChessGUI(engine)
    game.run()
